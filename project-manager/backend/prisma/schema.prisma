generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  Admin
  Faculty
  Lecturer
  Student
}

enum SubmissionStatus{
  PENDING
  SUBMITTED
  PASSED
  FAILED
}

enum CapstoneStatus {
  PENDING
  PENDING_LECTURER   // Đang chờ Giảng viên hướng dẫn duyệt
  REJECTED_LECTURER  // Bị Giảng viên từ chối (Được chọn lại GV)
  PENDING_FACULTY    // Đang chờ Khoa duyệt đề tài
  REJECTED_FACULTY   // Bị Khoa từ chối đề tài (Được chọn lại đề tài)
  DOING              // Khoa và GVHD đều đã duyệt -> Chính thức thực hiện
  SUBMITTED_FINAL    // Sinh viên đã nộp báo cáo cuối kỳ
  DEFENSE_ELIGIBLE   // Đủ điều kiện ra hội đồng bảo vệ
  COMPLETED          // Đã bảo vệ và có điểm cuối cùng
  FAILED             // Bị trượt
}

enum RequestStatus {
  PENDING
  APPROVED   
  REJECTED            
}

model Role {
  role_id    BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  role_name  UserRole  @unique
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @updatedAt @db.Timestamp(0)
  users      User[]
}

model User {
  user_id            BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  usercode           String              @unique @db.VarChar(50)
  username           String              @unique @db.VarChar(255)
  password           String              @db.VarChar(255)
  email              String              @unique @db.VarChar(255)
  fullname           String              @db.VarChar(255)
  gender             String?             @db.VarChar(10)
  phone_number       String?             @unique @db.VarChar(15)
  is_active          Boolean             @default(true)
  faculty_id         BigInt?             // Để Optional (?) vì tài khoản Admin tối cao thì không thuộc khoa nào cả
  faculty            Faculty?            @relation(fields: [faculty_id], references: [faculty_id], onDelete: Restrict, onUpdate: Cascade)

  managed_faculty    Faculty?            @relation("FacultyDean")

  first_login        Boolean             @default(true)
  role_id            BigInt              @db.UnsignedBigInt
  role               Role                @relation(fields: [role_id], references: [role_id], onDelete: Restrict, onUpdate: Cascade)
  created_at         DateTime?           @default(now()) @db.Timestamp(0)
  updated_at         DateTime?           @updatedAt @db.Timestamp(0)
  
  password_resets    PasswordReset[]
  student            StudentProfile?
  
  // Quan hệ bổ sung từ các bảng mới
  classes_managed    Class[]             // Giảng viên quản lý lớp cố vấn
  lecturer_expertises LecturerExpertise[] // Chuyên môn của giảng viên
  topics_created     Topic[]             // Đề tài do user này tạo ra
  student_capstones  Capstone?          @relation("StudentCapstones")
  lecturer_capstones Capstone[]          @relation("LecturerCapstones")
  council_memberships CouncilMember[]     // Tham gia vào hội đồng
  capstone_requests CapstoneRequest[] @relation("UserCapstoneRequests")
  council_evalution  CouncilEvalution[]
}

model PasswordReset {
  password_reset_id BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id           BigInt    @db.UnsignedBigInt
  user              User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  otp               String    @db.VarChar(10)
  expired_at        DateTime  @db.Timestamp(0)
  is_used           Boolean   @default(false)
  created_at        DateTime? @default(now()) @db.Timestamp(0)
}

model Faculty {
  faculty_id   BigInt       @id @default(autoincrement())
  faculty_code String       @unique @db.VarChar(20) // Ví dụ: 'CNTT', 'CK'
  name         String       @db.VarChar(255)        // Ví dụ: 'Công nghệ thông tin'
  created_at   DateTime?    @default(now()) @db.Timestamp(0)
  updated_at   DateTime?    @updatedAt @db.Timestamp(0)
  
  // Mối quan hệ liên kết ngược: Một khoa có nhiều chuyên môn
  majors       Major[]
  users        User[]
  capstones    Capstone[]
  topics       Topic[]
  dean_id      BigInt?   @unique @db.UnsignedBigInt
  dean         User?     @relation("FacultyDean", fields: [dean_id], references: [user_id], onDelete: SetNull, onUpdate: Cascade)
}

model Major {
  major_id   BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  major_name String    @db.VarChar(255)
  faculty_id BigInt    
  faculty    Faculty   @relation(fields: [faculty_id], references: [faculty_id], onDelete: Cascade, onUpdate: Cascade)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @updatedAt @db.Timestamp(0)
  class      Class[]
}

model Class {
  class_id    BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  class_name  String           @db.VarChar(255)

  major_id    BigInt           @db.UnsignedBigInt
  major       Major            @relation(fields: [major_id], references: [major_id], onDelete: Cascade, onUpdate: Cascade)
  lecturer_id BigInt           @db.UnsignedBigInt
  lecturer    User             @relation(fields: [lecturer_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  created_at  DateTime?        @default(now()) @db.Timestamp(0)
  updated_at  DateTime?        @updatedAt @db.Timestamp(0)
  students    StudentProfile[]
  
}

model StudentProfile {
  user_id  BigInt   @id @db.UnsignedBigInt
  user     User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  class_id BigInt   @db.UnsignedBigInt
  class    Class    @relation(fields: [class_id], references: [class_id])
  gpa      Decimal? @default(0.00) @db.Decimal(3, 2)
}

// ==========================================
// 2.8 Bảng academic_years (Năm học)
// ==========================================
model AcademicYear {
  year_id    BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  year_name  String     @db.VarChar(100)
  start_year Int        @db.Year
  end_year   Int        @db.Year
  created_at DateTime?  @default(now()) @db.Timestamp(0)
  updated_at DateTime?  @updatedAt @db.Timestamp(0)
  semesters  Semester[]
}

// ==========================================
// 2.9 Bảng semesters (Học kỳ)
// ==========================================
model Semester {
  semester_id   BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  year_id       BigInt        @db.UnsignedBigInt
  academic_year AcademicYear  @relation(fields: [year_id], references: [year_id], onDelete: Restrict, onUpdate: Cascade)
  semester_name String        @db.VarChar(100)
  start_date    DateTime      @db.Date
  end_date      DateTime      @db.Date
  created_at    DateTime?     @default(now()) @db.Timestamp(0)
  updated_at    DateTime?     @updatedAt @db.Timestamp(0)
  
  milestones    Milestone[]
  capstones     Capstone[]
  councils      Council[]
  
}

// ==========================================
// 2.10 Bảng milestones (Mốc thời gian nộp bài)
// ==========================================
model Milestone {
  milestone_id BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  semester_id  BigInt    @db.UnsignedBigInt
  semester     Semester  @relation(fields: [semester_id], references: [semester_id], onDelete: Cascade, onUpdate: Cascade)
  phase_name   String    @db.VarChar(255)
  description  String?   @db.Text
  deadline     DateTime  @db.DateTime(0)
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  updated_at   DateTime? @updatedAt @db.Timestamp(0)

  submission   CapstoneSubmission[]
}

// ==========================================
// 2.11 Bảng expertises (Lĩnh vực chuyên môn)
// ==========================================
model Expertise {
  expertise_id        BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  name                String              @unique @db.VarChar(255)
  description         String?             @db.Text
  created_at          DateTime?           @default(now()) @db.Timestamp(0)
  updated_at          DateTime?           @updatedAt @db.Timestamp(0)
  
  lecturer_expertises LecturerExpertise[]
  topics              Topic[]
}

// ==========================================
// 2.12 Bảng lecturer_expertises (Quan hệ M:N)
// ==========================================
model LecturerExpertise {
  lecturer_id  BigInt    @db.UnsignedBigInt
  lecturer     User      @relation(fields: [lecturer_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  expertise_id BigInt    @db.UnsignedBigInt
  expertise    Expertise @relation(fields: [expertise_id], references: [expertise_id], onDelete: Cascade, onUpdate: Cascade)
  created_at   DateTime? @default(now()) @db.Timestamp(0)

  @@id([lecturer_id, expertise_id])
}

// ==========================================
// 2.13 Bảng topics (Ngân hàng Đề tài)
// ==========================================
model Topic {
  topic_id      BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  expertise_id  BigInt    @db.UnsignedBigInt
  expertise     Expertise @relation(fields: [expertise_id], references: [expertise_id], onDelete: Restrict, onUpdate: Cascade)
  created_by    BigInt    @db.UnsignedBigInt
  creator       User      @relation(fields: [created_by], references: [user_id], onDelete: Restrict, onUpdate: Cascade)
  title         String    @db.VarChar(255)
  faculty_id    BigInt    
  faculty       Faculty   @relation(fields: [faculty_id], references: [faculty_id], onDelete: Cascade, onUpdate: Cascade)
  description   String?   @db.Text
  technologies  String    @db.Text
  is_bank_topic Boolean   @default(true)
  is_available  Boolean   @default(true)
  status        String    @default("APPROVED") @db.VarChar(50)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @updatedAt @db.Timestamp(0)
  
  capstones     Capstone[]
}

// ==========================================
// 2.14 Bảng capstones (Hồ sơ Đồ án Tốt nghiệp)
// ==========================================
model Capstone {
  capstone_id        BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  
  student_id         BigInt          @unique @db.UnsignedBigInt
  student            User            @relation("StudentCapstones", fields: [student_id], references: [user_id], onDelete: Restrict, onUpdate: Cascade)
  
  // OPTIONAL (Có dấu ?): Để sinh viên có thể đăng ký 1 trong 2 trước
  topic_id           BigInt?         @db.UnsignedBigInt
  topic              Topic?          @relation(fields: [topic_id], references: [topic_id], onDelete: Restrict, onUpdate: Cascade)
  
  lecturer_id        BigInt?         @db.UnsignedBigInt
  lecturer           User?           @relation("LecturerCapstones", fields: [lecturer_id], references: [user_id], onDelete: Restrict, onUpdate: Cascade)
  
  semester_id        BigInt          @db.UnsignedBigInt
  semester           Semester        @relation(fields: [semester_id], references: [semester_id], onDelete: Restrict, onUpdate: Cascade)
  
  council_id         BigInt?         @db.UnsignedBigInt
  council            Council?        @relation(fields: [council_id], references: [council_id], onDelete: SetNull, onUpdate: Cascade)
  
  status             CapstoneStatus  @default(PENDING) 
  faculty_id         BigInt    
  faculty            Faculty   @relation(fields: [faculty_id], references: [faculty_id], onDelete: Cascade, onUpdate: Cascade)
  final_report_path  String?         @db.VarChar(255)
  instructor_grade   Decimal?        @db.Decimal(4, 2)
  council_grade      Decimal?        @db.Decimal(4, 2)
  defense_order      Int?            @db.TinyInt
  
  created_at         DateTime?       @default(now()) @db.Timestamp(0)
  updated_at         DateTime?       @updatedAt @db.Timestamp(0)

  // Mối quan hệ tới bảng Lịch sử yêu cầu
  requests           CapstoneRequest[]
  submission         CapstoneSubmission[]
  council_evalution  CouncilEvalution[]
}

model CapstoneRequest {
  request_id   BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  
  capstone_id  BigInt    @db.UnsignedBigInt
  capstone     Capstone  @relation(fields: [capstone_id], references: [capstone_id], onDelete: Cascade, onUpdate: Cascade)
  
  sender_id    BigInt    @db.UnsignedBigInt
  sender       User      @relation("UserCapstoneRequests", fields: [sender_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  
  // Phân loại yêu cầu: "REGISTER_LECTURER" (Xin thầy hướng dẫn), "REGISTER_TOPIC" (Xin Khoa duyệt đề tài)
  request_type String    @db.VarChar(50) 
  
  // Nội dung sinh viên viết (VD: "Em muốn xin thầy hướng dẫn đề tài này ạ...")
  message      String    @db.Text 
  target_id    BigInt?           @db.UnsignedBigInt
  // Trạng thái của riêng cái request này: PENDING, APPROVED, REJECTED
  status       RequestStatus    @default(PENDING)
  
  // Lời nhắn phản hồi của GVHD hoặc Khoa (Đặc biệt dùng khi TỪ CHỐI để ghi lý do)
  feedback     String?   @db.Text 
  
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  updated_at   DateTime? @updatedAt @db.Timestamp(0)
}


model CapstoneSubmission {
  submission_id BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  capstone_id   BigInt     @db.UnsignedBigInt
  capstone     Capstone  @relation(fields: [capstone_id], references: [capstone_id], onDelete: Cascade, onUpdate: Cascade)

  milestone_id  BigInt     @db.UnsignedBigInt // Khóa ngoại liên kết bảng Milestone của bạn
  milestone     Milestone  @relation(fields: [milestone_id], references: [milestone_id], onDelete: Cascade, onUpdate: Cascade)

  file_path     String?    // Đường dẫn file báo cáo sinh viên nộp (.pdf, .zip)
  student_note  String?    @db.Text // Lời nhắn của sinh viên
  
  grade         Float?     // Điểm giảng viên chấm cho giai đoạn này
  lecturer_note String?    @db.Text // Lời nhận xét/feedback của giảng viên
  
  status        SubmissionStatus     @default(PENDING) // PENDING, PASSED, FAILED
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @updatedAt @db.Timestamp(0)
}
// ==========================================
// 2.15 Bảng councils (Hội đồng Bảo vệ)
// ==========================================
model Council {
  council_id  BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  semester_id BigInt          @db.UnsignedBigInt
  semester    Semester        @relation(fields: [semester_id], references: [semester_id], onDelete: Restrict, onUpdate: Cascade)
  name        String          @db.VarChar(255)
  buildings   String          @db.VarChar(255)
  rooms       String          @db.VarChar(255)
  start_date  DateTime?       @db.DateTime(0)
  end_date    DateTime?       @db.DateTime(0)
  created_at  DateTime?       @default(now()) @db.Timestamp(0)
  updated_at  DateTime?       @updatedAt @db.Timestamp(0)
  
  capstones   Capstone[]
  members     CouncilMember[]
}

// ==========================================
// 2.16 Bảng council_members (Quan hệ M:N)
// ==========================================
model CouncilMember {
  council_id  BigInt    @db.UnsignedBigInt
  council     Council   @relation(fields: [council_id], references: [council_id], onDelete: Cascade, onUpdate: Cascade)
  lecturer_id BigInt    @db.UnsignedBigInt
  lecturer    User      @relation(fields: [lecturer_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  position    String    @db.VarChar(100)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  updated_at  DateTime? @updatedAt @db.Timestamp(0)

  @@id([council_id, lecturer_id])
}

model CouncilEvalution {
  evalution_id  BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  members_id    BigInt    @db.UnsignedBigInt
  members       User      @relation(fields: [members_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  capstone_id   BigInt    @db.UnsignedBigInt
  capstone      Capstone  @relation(fields: [capstone_id], references: [capstone_id], onDelete: Cascade, onUpdate: Cascade)
  grade         Float?     
  lecturer_note String?  

  created_at  DateTime? @default(now()) @db.Timestamp(0)
  updated_at  DateTime? @updatedAt @db.Timestamp(0)
}
